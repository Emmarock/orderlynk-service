<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Phase 2: vendor subscription tiers. Adds a plan column to vendors (existing rows grandfathered
      onto STARTER at their legacy commission_rate), an admin-editable plan catalog (subscription_plans,
      seeded in code), and monthly subscription invoices (vendor_subscription_invoices, one per
      vendor+period — the unique constraint makes monthly generation idempotent). Portable: string UUID
      keys, enums as VARCHAR, money DECIMAL, rate DECIMAL with wide scale, no DB-level FKs.
    -->
    <changeSet id="031-vendor-plans" author="orderlynk">

        <addColumn tableName="vendors">
            <column name="plan" type="VARCHAR(20)" defaultValue="STARTER">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <createTable tableName="subscription_plans">
            <column name="id" type="VARCHAR(36)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
            <column name="plan" type="VARCHAR(20)"><constraints nullable="false" unique="true" uniqueConstraintName="uq_subscription_plan"/></column>
            <column name="display_name" type="VARCHAR(255)"><constraints nullable="false"/></column>
            <column name="monthly_fee" type="DECIMAL(19,2)" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="commission_rate" type="DECIMAL(12,6)" defaultValueNumeric="0"><constraints nullable="false"/></column>
            <column name="currency" type="VARCHAR(8)" defaultValue="CAD"><constraints nullable="false"/></column>
        </createTable>

        <createTable tableName="vendor_subscription_invoices">
            <column name="id" type="VARCHAR(36)"><constraints primaryKey="true" nullable="false"/></column>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
            <column name="vendor_id" type="VARCHAR(36)"><constraints nullable="false"/></column>
            <column name="plan" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="period_start" type="DATE"><constraints nullable="false"/></column>
            <column name="period_end" type="DATE"><constraints nullable="false"/></column>
            <column name="amount" type="DECIMAL(19,2)"><constraints nullable="false"/></column>
            <column name="currency" type="VARCHAR(8)" defaultValue="CAD"><constraints nullable="false"/></column>
            <column name="status" type="VARCHAR(20)" defaultValue="DUE"><constraints nullable="false"/></column>
            <column name="paid_at" type="DATETIME"/>
            <column name="reference" type="VARCHAR(255)"/>
        </createTable>
        <addUniqueConstraint tableName="vendor_subscription_invoices" columnNames="vendor_id, period_start"
                             constraintName="uq_vsi_vendor_period"/>
        <createIndex tableName="vendor_subscription_invoices" indexName="idx_vsi_vendor">
            <column name="vendor_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
