<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Email verification + password reset: a verified flag on users and a single-use token table. -->
    <changeSet id="006-user-email-verified" author="orderlynk">
        <addColumn tableName="users">
            <column name="email_verified" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="006-user-tokens" author="orderlynk">
        <createTable tableName="user_tokens">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
            <column name="user_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="token" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="used_at" type="DATETIME"/>
        </createTable>
        <createIndex tableName="user_tokens" indexName="idx_user_token_value" unique="true">
            <column name="token"/>
        </createIndex>
        <createIndex tableName="user_tokens" indexName="idx_user_token_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>