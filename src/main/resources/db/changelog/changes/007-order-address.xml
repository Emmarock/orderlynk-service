<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Full delivery address on orders to aid fulfillment. -->
    <changeSet id="007-order-address" author="orderlynk">
        <addColumn tableName="orders">
            <column name="customer_house_number" type="VARCHAR(255)"/>
            <column name="customer_street" type="VARCHAR(512)"/>
            <column name="customer_postcode" type="VARCHAR(40)"/>
            <column name="customer_country" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>