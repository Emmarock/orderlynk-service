<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Deduplication store for inbound payment-service events (at-least-once delivery). -->
    <changeSet id="014-payment-events" author="orderlynk">
        <createTable tableName="processed_payment_events">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
            <column name="event_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="VARCHAR(64)"/>
        </createTable>
        <addUniqueConstraint tableName="processed_payment_events" columnNames="event_id"
                             constraintName="uq_processed_payment_event"/>
    </changeSet>
</databaseChangeLog>