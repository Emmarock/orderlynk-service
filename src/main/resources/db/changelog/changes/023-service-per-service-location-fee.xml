<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Per-service location + travel fee (overrides the provider-level defaults). -->
    <changeSet id="023-add-location-and-fee-to-services" author="babajide">
        <addColumn tableName="services">
            <column name="location_type" type="varchar(32)" defaultValue="AT_PROVIDER">
                <constraints nullable="false"/>
            </column>
            <column name="customer_location_fee" type="decimal(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>