<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
      Reusable address model. The vendor's single business address reuses the existing
      city/country columns and gains house number / street / postcode. Customers get an
      address book (many addresses, one default).
    -->
    <changeSet id="008-vendor-address" author="orderlynk">
        <addColumn tableName="vendors">
            <column name="address_house_number" type="VARCHAR(255)"/>
            <column name="address_street" type="VARCHAR(512)"/>
            <column name="address_postcode" type="VARCHAR(40)"/>
        </addColumn>
    </changeSet>

    <changeSet id="008-customer-addresses" author="orderlynk">
        <createTable tableName="customer_addresses">
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="created_at" type="DATETIME"/>
            <column name="updated_at" type="DATETIME"/>
            <column name="user_id" type="VARCHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="label" type="VARCHAR(60)"/>
            <column name="house_number" type="VARCHAR(255)"/>
            <column name="street" type="VARCHAR(512)"/>
            <column name="city" type="VARCHAR(255)"/>
            <column name="postcode" type="VARCHAR(40)"/>
            <column name="country" type="VARCHAR(255)"/>
            <column name="is_default" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createIndex tableName="customer_addresses" indexName="idx_customer_address_user">
            <column name="user_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>