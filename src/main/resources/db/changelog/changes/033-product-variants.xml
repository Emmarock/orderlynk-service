<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Selectable product variant options (e.g. clothing colours and sizes). Stored as ordered
         value lists on the product; the customer's chosen values are snapshotted onto order items. -->
    <changeSet id="033-create-product-colors" author="babajide">
        <createTable tableName="product_colors">
            <column name="product_id" type="VARCHAR(36)"><constraints nullable="false"/></column>
            <column name="position" type="INT"><constraints nullable="false"/></column>
            <column name="color" type="VARCHAR(64)"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="product_colors" indexName="idx_product_colors_product">
            <column name="product_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="033-create-product-sizes" author="babajide">
        <createTable tableName="product_sizes">
            <column name="product_id" type="VARCHAR(36)"><constraints nullable="false"/></column>
            <column name="position" type="INT"><constraints nullable="false"/></column>
            <column name="size" type="VARCHAR(64)"><constraints nullable="false"/></column>
        </createTable>
        <createIndex tableName="product_sizes" indexName="idx_product_sizes_product">
            <column name="product_id"/>
        </createIndex>
    </changeSet>

    <!-- Snapshot of the variant the customer selected, immune to later product edits. -->
    <changeSet id="033-add-variant-to-order-items" author="babajide">
        <addColumn tableName="order_items">
            <column name="selected_color" type="VARCHAR(64)"/>
            <column name="selected_size" type="VARCHAR(64)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>
