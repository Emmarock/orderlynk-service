<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Correlate async delivery-status callbacks (e.g. Twilio) to a notification log row. -->
    <changeSet id="010-notification-provider-id" author="orderlynk">
        <addColumn tableName="notification_logs">
            <column name="provider_message_id" type="VARCHAR(64)"/>
        </addColumn>
        <createIndex tableName="notification_logs" indexName="idx_notification_provider_msg">
            <column name="provider_message_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>