<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Optional image per sub-service / variant, shown to customers when choosing an option. -->
    <changeSet id="026-add-image-to-service-variants" author="babajide">
        <addColumn tableName="service_variants">
            <column name="image_url" type="VARCHAR(1024)"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>