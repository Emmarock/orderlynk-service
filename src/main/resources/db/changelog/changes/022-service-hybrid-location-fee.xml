<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Hybrid service location (at-provider OR at-customer) with a configurable travel surcharge. -->
    <changeSet id="022-add-customer-location-fee-to-profile" author="babajide">
        <addColumn tableName="service_provider_profiles">
            <column name="customer_location_fee" type="decimal(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="022-add-travel-fee-to-bookings" author="babajide">
        <addColumn tableName="bookings">
            <column name="travel_fee" type="decimal(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>